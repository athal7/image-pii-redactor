{
  "name": "image-pii-redactor",
  "version": "0.3.6",
  "description": "Client-side PII redaction for screenshot images. OCR + NER in the browser — your data never leaves your device.",
  "type": "module",
  "main": "dist/image-pii-redactor.js",
  "module": "dist/image-pii-redactor.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/image-pii-redactor.js",
      "types": "./dist/index.d.ts"
    },
    "./component": {
      "import": "./dist/image-pii-redactor.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "VITE_RUNNING=1 playwright test",
    "test:e2e:ui": "VITE_RUNNING=1 playwright test --ui",
    "test:e2e:fast": "VITE_RUNNING=1 playwright test --grep 'trust banner|drop zone|invalid file|mobile viewport'",
    "test:all": "vitest run && VITE_RUNNING=1 playwright test"
  },
  "keywords": [
    "pii",
    "redaction",
    "privacy",
    "ocr",
    "ner",
    "client-side",
    "browser",
    "image",
    "screenshot",
    "web-component",
    "tesseract",
    "transformers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/athal7/image-pii-redactor"
  },
  "homepage": "https://athal7.github.io/image-pii-redactor/",
  "bugs": {
    "url": "https://github.com/athal7/image-pii-redactor/issues"
  },
  "license": "MPL-2.0",
  "dependencies": {
    "@xenova/transformers": "^2.17.0",
    "lit": "^3.2.0",
    "tesseract.js": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.0.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
