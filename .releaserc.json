{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "npm run build && npm publish --provenance --access public"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/image-pii-redactor.js", "label": "Library bundle (ESM)" }
        ]
      }
    ]
  ]
}
